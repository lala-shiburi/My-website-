---
import Nav from '../../components/Nav.astro'
import { getCollection, getEntry, render } from 'astro:content'

export async function getStaticPaths() {
  const posts = await getCollection('journal')
  return posts.map(post => ({
    params: { slug: post.id },
  }))
}

const { slug } = Astro.params
const post = await getEntry('journal', slug)

if (!post) return Astro.redirect('/404')

const { Content } = await render(post)

// Format the date
const formattedDate = new Date(post.data.date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{post.data.title}</title>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <main>
      <article class="post">
        <a href="/journal" class="back-link">← Back to journal</a>

        <header>
          <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
          <h1>{post.data.title}</h1>
          <p class="excerpt">{post.data.excerpt}</p>
        </header>

        <div class="content">
          <Content />
        </div>

        <footer class="post-footer">
          <a href="/journal" class="back-link">← All entries</a>
        </footer>
      </article>
    </main>
  </body>
</html>

<style>
  body {
    background: var(--bg);
    color: var(--text-primary);
    font-family: var(--mono);
  }

  main {
    max-width: 1200px;
    margin: 0 auto;
  }

  .post {
    max-width: 720px;
    margin: 0 auto;
    padding: 4rem 2rem;
  }

  .back-link {
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    color: var(--text-faint);
    text-decoration: none;
    transition: color 0.15s ease;
  }

  .back-link:hover {
    color: var(--accent);
  }

  header {
    margin-top: 2rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  time {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    color: var(--text-faint);
  }

  h1 {
    margin-top: 0.5rem;
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 700;
    line-height: 1.3;
  }

  .excerpt {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Markdown content styling */
  .content {
    margin-top: 3rem;
    line-height: 1.8;
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .content :global(h2) {
    color: var(--text-primary);
    font-size: 1.1rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }

  .content :global(h3) {
    color: var(--text-primary);
    font-size: 0.95rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .content :global(p) {
    margin-top: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-top: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(li) {
    margin-top: 0.5rem;
  }

  .content :global(code) {
    background: rgba(255, 255, 255, 0.06);
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.8rem;
  }

  .content :global(pre) {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid var(--border);
    padding: 1.25rem;
    margin-top: 1.5rem;
    overflow-x: auto;
    font-size: 0.8rem;
    line-height: 1.6;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
  }

  .content :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding-left: 1rem;
    margin-top: 1.5rem;
    color: var(--text-muted);
    font-style: italic;
  }

  .content :global(a) {
    color: var(--accent);
    text-decoration: none;
  }

  .content :global(a:hover) {
    text-decoration: underline;
  }

  .post-footer {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  @media (max-width: 768px) {
    .post {
      padding: 2rem 1rem;
    }
  }
</style>