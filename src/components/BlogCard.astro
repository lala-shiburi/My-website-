---
// BlogCard.astro
export interface Props {
  title: string
  date: string | Date
  slug: string
  excerpt?: string
}

const { title, date, slug, excerpt } = Astro.props

const formatted = new Date(date).toLocaleDateString('en-US', {
  month: 'short',
  day:   '2-digit',
  year:  'numeric',
}).toUpperCase()
---

<a href={`/journal/${slug}`} class="blog-card">
  <span class="date">{formatted}</span>
  <h3 class="title">{title}</h3>
  {excerpt && <p class="excerpt">{excerpt}</p>}
  <span class="read-more">
    READ_ENTRY
    <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
      <path d="M1 9L9 1M9 1H3M9 1V7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </span>
</a>

<style>
  .blog-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1.5rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    text-decoration: none;
    font-family: 'JetBrains Mono', 'IBM Plex Mono', monospace;
    background: #0a0a0a;
    transition: border-color 0.2s ease, background 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  /* Teal corner accent that grows on hover */
  .blog-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 2px;
    height: 0;
    background: #0d9e75;
    transition: height 0.25s ease;
  }

  .blog-card:hover {
    border-color: rgba(255, 255, 255, 0.18);
    background: #0d0d0d;
  }

  .blog-card:hover::before {
    height: 100%;
  }

  .date {
    font-size: 0.6rem;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.25);
  }

  .title {
    font-size: 0.9rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.3;
    letter-spacing: -0.01em;
    transition: color 0.15s ease;
  }

  .blog-card:hover .title {
    color: #0d9e75;
  }

  .excerpt {
    font-size: 0.7rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.35);
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.2);
    margin-top: auto;
    padding-top: 0.5rem;
    transition: color 0.15s ease, gap 0.2s ease;
  }

  .blog-card:hover .read-more {
    color: #0d9e75;
    gap: 8px;
  }
</style>